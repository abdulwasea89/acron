# App
APP_ENV=development
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# Toggle: yes -> use CLOUD_DATABASE_URL (Neon/Supabase). no -> local SQLite file.
USE_CLOUD_DB=no
# Neon/Supabase connection string. sslmode/channel_binding params are stripped
# automatically; the postgres:// scheme is upgraded to postgresql+asyncpg://.
CLOUD_DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
LOCAL_DATABASE_URL=sqlite+aiosqlite:///./gym_platform.db

# Redis (Celery broker + rate limiting + idempotency cache)
REDIS_URL=XXXXX

# Stripe (platform SaaS billing + Connect)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx

# Email / Push
EMAIL_FROM=XXXX
SMTP_URL=XXXX 

# AI receipt verification
OCR_PROVIDER_API_KEY=

# Security
HIBP_API_URL=https://api.pwnedpasswords.com

